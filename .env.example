# South Flowers Portal Environment Variables
# Copy this file to .env.local for local development

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/south_flowers"

# Authentication
NEXTAUTH_SECRET="your-super-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# API Keys (if using external services)
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_key"
STRIPE_SECRET_KEY="sk_test_your_stripe_secret"

# Email Service (for member notifications)
RESEND_API_KEY="re_your_resend_api_key"
FROM_EMAIL="noreply@southflowers.mt"

# External APIs (if needed)
FLOWER_API_KEY="your_flower_supplier_api_key"

# Development/Production
NODE_ENV="development"